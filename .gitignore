# yingzaofashi_rag_backend — Python / FastAPI / LangChain RAG

# === 用户自定义及项目清理 ===
.cursor/


# === 核心目录 (针对已经在根目录产生的虚拟环境软链接) ===
bin/
include/
lib/
lib64/
pyvenv.cfg
share/

# === Python 虚拟环境 (标准路径) ===
.venv/
venv/
env/
ENV/
# .python-version 由 uv pin 生成，建议纳入版本控制以统一本地/CI Python 版本

# Python cache / bytecode
__pycache__/
*.py[cod]
*$py.class
*.so


# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test / coverage / type check caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Logs and temp files
*.log
*.pid
*.out
*.err
*.tmp
tmp/
.cache/

# Environment / secrets
.env
.env.*
!.env.example
.pgpass
db/

# 本地 SQLite / 临时库文件（主库为 PostgreSQL，此处防误提交本地测试库）
*.sqlite
*.sqlite3
*.db


# IDE / editor
